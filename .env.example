# Backend origin the API client talks to (no trailing slash).
VITE_SERVER_URL="your server URL here"

# (optional) Sentry DSN for browser error tracking. Leave unset to disable
# Sentry entirely - the SDK is lazy-loaded only when this is present.
# VITE_SENTRY_DSN=

# (optional) Canonical site origin used for SEO tags and sitemap generation
# (scripts/generate-seo.mjs). Defaults to https://bethere.manuru.dev.
# VITE_SITE_URL=

# (optional, CI/build only) Sentry auth token for uploading production source
# maps via @sentry/vite-plugin. Without it the build skips the upload and
# Sentry events show minified frames.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
